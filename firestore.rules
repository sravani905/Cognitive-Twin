rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sravani.ghattu@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['uid', 'role', 'content', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.content is string &&
             data.timestamp is number;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['uid', 'metrics', 'insights', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.metrics is map &&
             data.insights is map &&
             data.timestamp is number;
    }

    function isValidRoadmap(data) {
      return data.keys().hasAll(['uid', 'careerTitle', 'phases', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.careerTitle is string &&
             data.phases is list &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /chats/{chatId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidChat(request.resource.data);
      }

      match /results/{resultId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidResult(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /roadmaps/{roadmapId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidRoadmap(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Feedback collection (if used)
    match /feedback/{id} {
      allow create: if isAuthenticated();
    }

    match /sharedReports/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
    }
  }
}
